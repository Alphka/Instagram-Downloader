{
	"author": "Kayo Souza",
	"name": "insta-downloader",
	"version": "4.0.0",
	"description": "An application to download content from Instagram",
	"main": "src/index.js",
	"scripts": {
		"start": "node .",
		"test": "node --test tests/index.test.js",
		"test:watch": "node --test --watch tests/index.test.js",
		"lint": "eslint . --cache",
		"lint:fix": "eslint . --cache --fix"
	},
	"keywords": [
		"instagram",
		"download",
		"last-modified",
		"pictures",
		"images",
		"photos",
		"videos"
	],
	"dependencies": {
		"axios": "^1.17.0",
		"chalk": "^5.6.2",
		"commander": "^12.1.0",
		"cross-spawn": "^7.0.6",
		"mime": "^4.1.0",
		"sharp": "^0.34.5",
		"which": "^7.0.0"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3.3.5",
		"@stylistic/eslint-plugin": "^5.10.0",
		"@total-typescript/ts-reset": "^0.6.1",
		"@types/cross-spawn": "^6.0.6",
		"@types/node": "^25.9.2",
		"@types/which": "^3.0.4",
		"eslint": "^10.4.1",
		"eslint-plugin-n": "^18.1.0",
		"eslint-plugin-regexp": "^3.1.0",
		"eslint-plugin-sonarjs": "^4.0.3",
		"eslint-plugin-unicorn": "^65.0.1",
		"eslint-plugin-unused-imports": "^4.4.1",
		"globals": "^17.6.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.61.0"
	},
	"overrides": {
		"eslint": "$eslint",
		"eslint-plugin-n": {
			"typescript": "$typescript"
		},
		"globals": "$globals"
	},
	"allowScripts": {
		"sharp@0.34.5": true
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Alphka/Instagram-Downloader.git"
	},
	"bugs": {
		"url": "https://github.com/Alphka/Instagram-Downloader/issues"
	},
	"homepage": "https://github.com/Alphka/Instagram-Downloader#readme",
	"bin": {
		"instadl": "src/index.js"
	},
	"engines": {
		"node": "^22.22 || ^23.8 || >=24",
		"pnpm": "^10.26 || 11"
	},
	"license": "ISC",
	"type": "module"
}
