{
	"cSpell.enabled": true,
	"cSpell.language": "en",
	"cSpell.words": [
		"Alphka",
		"andybalholm",
		"apng",
		"besties",
		"Csrftoken",
		"datr",
		"dtsg",
		"fatih",
		"ftyp",
		"GOPATH",
		"greyscale",
		"hcover",
		"heim",
		"heis",
		"heix",
		"hevm",
		"hevs",
		"hevx",
		"IDAT",
		"IEND",
		"IHDR",
		"Infof",
		"initialises",
		"Inrelayprovider",
		"instadl",
		"instagr",
		"instagraaaaaaaaaaaaaaaaaaaaaaam",
		"KHTML",
		"klauspost",
		"ldflags",
		"loglevel",
		"mattn",
		"mpdecimate",
		"relayprovider",
		"scanline",
		"sessionid",
		"Souza",
		"trimpath",
		"TTFB",
		"vcodec",
		"webp"
	],
	"cSpell.ignorePaths": [
		"vscode-extension",
		".git/{info,lfs,logs,refs,objects}/**",
		".git/{index,*refs,*HEAD}",
		".gitignore",
		".vscode",
		".vscode-insiders",
		"vendor",
		"go.sum",
		"go.mod"
	],

	"editor.insertSpaces": false,

	"files.eol": "\n",
	"files.insertFinalNewline": true,
	"files.trimTrailingWhitespace": true,
	"files.trimFinalNewlines": true,

	"[markdown]": {
		"diffEditor.ignoreTrimWhitespace": false,
		"editor.insertSpaces": true,
		"editor.tabSize": 2,
		"editor.wordWrap": "on",
		"editor.unicodeHighlight.ambiguousCharacters": false,
		"editor.unicodeHighlight.invisibleCharacters": false,
		"editor.quickSuggestions": {
			"comments": "on",
			"strings": "on",
			"other": "on"
		},
		"files.trimTrailingWhitespace": false
	},

	"[yaml]": {
		"editor.insertSpaces": true,
		"editor.tabSize": 2,
		"editor.autoIndent": "advanced",
		"diffEditor.ignoreTrimWhitespace": false,
		"files.trimTrailingWhitespace": false
	},
}
