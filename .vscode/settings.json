{
	"cSpell.enabled": true,
	"cSpell.language": "en",
	"cSpell.words": [
		"apng",
		"Asbd",
		"bestie",
		"besties",
		"bloks",
		"commerciality",
		"crosspost",
		"csrftoken",
		"csvqm",
		"datr",
		"dotenv",
		"dtsg",
		"ehthumbs",
		"eligiblity",
		"eslintcache",
		"facepile",
		"filenamify",
		"fxcal",
		"hcover",
		"IEND",
		"igtv",
		"igweb",
		"informations",
		"Inrelayprovider",
		"insta",
		"instadl",
		"instagr",
		"instagraaaaaaaaaaaaaaaaaaaaaaam",
		"KHTML",
		"millis",
		"mpdecimate",
		"nonconstructor",
		"nonmimicable",
		"nonoctal",
		"nonwords",
		"nothrow",
		"Qube",
		"reattribution",
		"relayprovider",
		"reshare",
		"reshared",
		"scannerwork",
		"sessionid",
		"Souza",
		"spritesheet",
		"Subsampling",
		"Turborepo",
		"upsell",
		"usertags",
		"vcodec",
		"vercel",
		"Vercel",
		"zstd"
	],
	"cSpell.ignorePaths": [
		"package-lock.json",
		"pnpm-lock.yaml",
		"pnpm-workspace.yaml",
		"node_modules",
		".git/{info,lfs,logs,refs,objects}/**",
		".git/{index,*refs,*HEAD}",
		".vscode"
	],

	"js/ts.format.indentSwitchCase": true,
	"js/ts.format.insertSpaceAfterConstructor": false,
	"js/ts.format.insertSpaceAfterCommaDelimiter": true,
	"js/ts.format.insertSpaceAfterSemicolonInForStatements": true,
	"js/ts.format.insertSpaceAfterKeywordsInControlFlowStatements": false,
	"js/ts.format.insertSpaceAfterOpeningAndBeforeClosingEmptyBraces": false,
	"js/ts.format.insertSpaceAfterFunctionKeywordForAnonymousFunctions": false,
	"js/ts.format.insertSpaceAfterOpeningAndBeforeClosingNonemptyBraces": true,
	"js/ts.format.insertSpaceAfterOpeningAndBeforeClosingNonemptyBrackets": false,
	"js/ts.format.insertSpaceAfterOpeningAndBeforeClosingNonemptyParenthesis": false,
	"js/ts.format.insertSpaceAfterOpeningAndBeforeClosingJsxExpressionBraces": false,
	"js/ts.format.insertSpaceAfterOpeningAndBeforeClosingTemplateStringBraces": false,
	"js/ts.format.insertSpaceAfterTypeAssertion": true,
	"js/ts.format.insertSpaceBeforeAndAfterBinaryOperators": true,
	"js/ts.format.insertSpaceBeforeFunctionParenthesis": false,
	"js/ts.format.placeOpenBraceOnNewLineForFunctions": false,
	"js/ts.format.placeOpenBraceOnNewLineForControlBlocks": false,
	"js/ts.format.semicolons": "remove",
	"js/ts.preferences.importModuleSpecifier": "shortest",
	"js/ts.preferences.importModuleSpecifierEnding": "minimal",
	"js/ts.preferences.preferTypeOnlyAutoImports": true,
	"js/ts.preferences.quoteStyle": "double",
	"js/ts.reportStyleChecksAsWarnings": true,
	"js/ts.tsdk.promptToUseWorkspaceVersion": false,

	"eslint.enable": true,
	"eslint.format.enable": true,

	"editor.insertSpaces": false,

	"[javascript]": {
		"editor.defaultFormatter": "dbaeumer.vscode-eslint"
	},

	"[typescript]": {
		"editor.defaultFormatter": "dbaeumer.vscode-eslint"
	},

	"files.eol": "\n",
	"files.insertFinalNewline": true,
	"files.trimTrailingWhitespace": true,
	"files.trimFinalNewlines": true,

	"[markdown]": {
		"diffEditor.ignoreTrimWhitespace": false,
		"editor.insertSpaces": true,
		"editor.tabSize": 2,
		"files.trimTrailingWhitespace": false
	},

	"[yaml]": {
		"editor.insertSpaces": true,
		"editor.tabSize": 2,
		"editor.autoIndent": "advanced"
	},

	"npm-intellisense.importES6": true,
	"npm-intellisense.importQuotes": "\"",
	"npm-intellisense.importLinebreak": "\n"
}
